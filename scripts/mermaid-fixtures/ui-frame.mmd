%%{init: {"flowchart": {"curve": "basis"}}}%%
flowchart TD
    subgraph iphone["iPhone 393×852"]
        direction TB
        ui_N0("Knapp"):::ui
        %% ui_N0 pos: 100,200
        %% ui_N0 name: Knapp
        ui_N1("Rubrik"):::ui
        %% ui_N1 pos: 100,100
        %% ui_N1 name: Rubrik
        zone_N2("Lista"):::zone
        %% zone_N2 pos: 100,300
        %% zone_N2 name: Lista
        ui_N1 --> ui_N0
    end

    %% legend ui: UI-element — text syns på skärmen.
    %% legend zone: Layout-zon — region för UI.

    classDef ui fill:#ffffff,stroke:#1e293b,color:#111827,font-weight:normal;
    classDef zone fill:#ffffff,stroke:#9ca3af,color:#111827,font-weight:normal;
    classDef iphone fill:#f8fafc,stroke:#0f172a,stroke-width:2px,color:#0f172a;
    class iphone iphone;